# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/atp_auth

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=auth:

# ── JWT (RS256 — base64-encoded PEM keys) ─────────────────────
JWT_PRIVATE_KEY=<base64-encoded RSA-2048 private key PEM>
JWT_PUBLIC_KEY=<base64-encoded RSA-2048 public key PEM>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER=atp-auth-service
JWT_AUDIENCE=atp-content-service,atp-evaluation-service

# ── SendGrid ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI Teaching Platform
SENDGRID_TEMPLATE_VERIFY=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_RESET=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_PWD_CHANGED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth2 ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ── GitHub OAuth2 ─────────────────────────────────────────────
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── OTP Settings ──────────────────────────────────────────────
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=3
OTP_MAX_RESENDS=3
OTP_RESEND_WINDOW_SECONDS=1800

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5

# ── Bcrypt ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
